{
  "name": "set-ecs-desired-task-count-zero",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "license": "ISC",
  "author": "Kay Cheung",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "docker:install": "docker run --rm --platform=linux/amd64 -v \"$PWD\":/var/task -w /var/task node:24 bash -lc \"rm -rf node_modules package-lock.json && npm install --include=optional\"",
    "zip": "rm -f function.zip && zip -r function.zip . -x \"*.DS_Store\" -x \".env\" -x \"*.git*\" -x \"function.zip\"",
    "build": "npm run docker:install && npm run zip",
    "deploy": "aws lambda update-function-code --function-name set-ecs-desired-task-count-zero --zip-file fileb://function.zip"
  },
  "dependencies": {
    "@aws-sdk/client-ecs": "^3.1026.0"
  }
}
