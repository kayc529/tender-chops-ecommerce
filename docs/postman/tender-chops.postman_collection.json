        {
          "name": "(Admin) Create Image Upload URL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test(\"Response has uploadUrl\", () => {",
                  "  pm.expect(res).to.have.property(\"uploadUrl\");",
                  "  pm.expect(res.quoteId).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Response has expectedContentType\", () => {",
                  "  pm.expect(res).to.have.property(\"expectedContentType\");",
                  "  pm.expect(res.quoteId).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.environment.set(\"product_image_presigned_url\", res.uploadUrl);",
                  "pm.environment.set(\"expected_content_type\", res.expectedContentType);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{ACCESS_TOKEN}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"contentType\":\"image/png\",\n    \"originalFilename\":\"salmon-fillet.png\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{PRODUCT_SERVICE_BASE_URL}}/admin/products/{{product_id}}/image-upload-url",
